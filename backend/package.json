  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@prisma/client": "^5.22.0",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
