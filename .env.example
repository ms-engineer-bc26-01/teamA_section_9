# DB設定
POSTGRES_USER=user
POSTGRES_PASSWORD=
POSTGRES_DB=skinmate_db

# Prisma用
LOCAL_DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/skinmate_db?schema=public"

# Docker用
DOCKER_DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public"

# 実行環境
NODE_ENV=development

# OpenAI API
OPENAI_API_KEY=
